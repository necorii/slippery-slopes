name: Build iOS IPA
on: [push]

jobs:
  build:
    runs-on: macos-latest
    steps:
      - name: Checkout Code
        uses: actions/checkout@v4
      
      - name: Build Raylib for iOS
        run: |
          git clone --depth 1 https://github.com/raysan5/raylib.git
          cd raylib/src
          # We stay in this folder to find all the .c files
          xcrun -sdk iphoneos clang -c rcore.c rshapes.c rtextures.c rtext.c rmodels.c raudio.c rglfw.c \
            -Os -Wall -DPLATFORM_ANDROID -DGRAPHICS_API_OPENGL_ES2 \
            -isysroot $(xcrun --sdk iphoneos --show-sdk-path) \
            -target arm64-apple-ios15.0 \
            -I. -Iexternal/glfw/include
          
          # Create the library archive (.a)
          ar rcs libraylib.a rcore.o rshapes.o rtextures.o rtext.o rmodels.o raudio.o rglfw.o
          
          # Now move it back to our main folder so the next step can find it
          mkdir -p ../../lib
          cp libraylib.a ../../lib/
          cp raylib.h raymath.h rcamera.h rgestures.h rlgl.h ../../
          cd ../../

      - name: Build Binary
        run: |
          # Link your game against the freshly baked iOS Raylib
          xcrun -sdk iphoneos clang main.c -o SlipperySlopes \
            -I. -L./lib -lraylib \
            -Os -Wall -target arm64-apple-ios15.0 \
            -isysroot $(xcrun --sdk iphoneos --show-sdk-path) \
            -DPLATFORM_ANDROID -DGRAPHICS_API_OPENGL_ES2 \
            -framework CoreGraphics -framework UIKit -framework Foundation \
            -framework QuartzCore -framework OpenGLES -framework AudioToolbox -lm

      - name: Package IPA
        run: |
          # Create the iOS App Bundle structure
          mkdir -p Payload/SlipperySlopes.app
          
          # Move binary and assets into the bundle
          mv SlipperySlopes Payload/SlipperySlopes.app/
          cp *.png Payload/SlipperySlopes.app/ 2>/dev/null || true
          cp *.wav Payload/SlipperySlopes.app/ 2>/dev/null || true
          cp *.ttf Payload/SlipperySlopes.app/ 2>/dev/null || true
          
          # Zip it into an IPA
          zip -r SlipperySlopes.ipa Payload/

      - name: Upload Artifact
        uses: actions/upload-artifact@v4
        with:
          name: SlipperySlopes-iOS-Unsigned
          path: SlipperySlopes.ipa